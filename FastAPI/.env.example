# Rename this file to .env and fill in your values

# Email alert credentials (use a Gmail App Password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here

# Path to trained ML model files (default: ../models relative to FastAPI/)
MODEL_DIR=

# Frontend URL (for CORS, dev default is http://localhost:3000)
FRONTEND_URL=http://localhost:3000
