# FastAPI-level gitignore (nested inside the FastAPI/ folder)

# Python bytecode
__pycache__/
*.py[cod]
*.pyo

# Virtual environment
venv/
.venv/

# Secrets
.env

# Trained ML models (.pkl) — regenerated by train_models.py
../models/*.pkl

# yfinance cache
*.db
*.sqlite
*.sqlite3
yfinance_tz_cache/

# Frontend build output
frontend/dist/
frontend/node_modules/
